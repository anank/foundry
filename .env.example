ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
FOUNDRY_LOG_LEVEL=INFO

# SQLite database path (default: ~/.foundry/foundry.db)
FOUNDRY_DB_PATH=

# Device ID — must match the device_id you set in the Devices page for this machine
FOUNDRY_DEVICE_ID=my-machine

# GitHub token — for fetching commit history on project detail pages
GITHUB_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
